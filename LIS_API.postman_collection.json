            "url": {"raw": "http://127.0.0.1:8000/api/v1/orders/1/receive/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "v1", "orders", "1", "receive", ""]}
          }
        },
        {
          "name": "Enter Results",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"results\": [\n    {\n      \"assay\": 1,\n      \"result_value\": \"7.5\",\n      \"unit\": \"x10³/µL\",\n      \"normal_range\": \"4.5-11.0\",\n      \"flag\": \"N\",\n      \"remarks\": \"Within normal limits\"\n    }\n  ]\n}"
            },
            "url": {"raw": "http://127.0.0.1:8000/api/v1/orders/1/results/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "v1", "orders", "1", "results", ""]}
          }
        },
        {
          "name": "Get Lab Report",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "http://127.0.0.1:8000/api/v1/orders/1/report/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "v1", "orders", "1", "report", ""]}
