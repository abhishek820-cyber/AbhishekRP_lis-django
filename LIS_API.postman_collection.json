            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_name\": \"Test Patient\",\n  \"age\": 30,\n  \"gender\": \"Male\",\n  \"nationality\": \"Indian\",\n  \"status\": \"Active\"\n}"
            },
            "url": {"raw": "http://127.0.0.1:8000/api/v1/patients/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "v1", "patients", ""]}
          }
        },
        {
          "name": "Get Patient Detail",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "http://127.0.0.1:8000/api/v1/patients/1/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "v1", "patients", "1", ""]}
          }
        }
      ]
    },
