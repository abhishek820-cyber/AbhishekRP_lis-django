            "url": {"raw": "http://127.0.0.1:8000/api/v1/orders/1/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "v1", "orders", "1", ""]}
          }
        },
        {
          "name": "Collect Sample (Phlebotomist)",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "http://127.0.0.1:8000/api/v1/orders/1/collect/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "v1", "orders", "1", "collect", ""]}
