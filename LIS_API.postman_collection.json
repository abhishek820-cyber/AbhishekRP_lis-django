{
  "info": {
    "name": "LIS API Collection",
    "description": "Laboratory Information System — REST API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"your_password\"\n}"
            },
            "url": {"raw": "http://127.0.0.1:8000/api/v1/auth/login/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "v1", "auth", "login", ""]}
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {"raw": "http://127.0.0.1:8000/api/v1/auth/logout/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "v1", "auth", "logout", ""]}
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {"raw": "http://127.0.0.1:8000/api/v1/auth/token/refresh/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "v1", "auth", "token", "refresh", ""]}
          }
        }
      ]
    },
    {
